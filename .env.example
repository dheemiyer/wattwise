# EIA API key -- get one free in 2 minutes at:
# https://www.eia.gov/opendata/register.php
# Without it, WattWise uses a realistic modeled grid curve (source = "mock").
EIA_API_KEY=

# Optional: route EIA calls through an HTTPS proxy (needed on corporate
# networks where api.eia.gov isn't directly reachable). Standard HTTPS_PROXY
# is also honored. Example (Walmart):
# EIA_PROXY=http://sysproxy.wal-mart.com:8080
EIA_PROXY=
